{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@pos-mono/source"],
    "paths": {
      "@pos-mono/quote-form-ui": ["./libs/poseidon/quote-form-ui/src/index.ts"],
      "@pos-mono/quote-form": ["./libs/poseidon/quote-form/src/index.tsx"],
      "@pos-mono/poseidon-api": ["./libs/poseidon-api/src/index.ts"],
      "@pos-mono/authentication": ["./libs/authentication/src/index.ts"]
    }
  }
}
